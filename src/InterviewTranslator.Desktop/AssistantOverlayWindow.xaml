<Window x:Class="InterviewTranslator.Desktop.AssistantOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IT Assistant"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        MinWidth="320" MinHeight="80"
        Width="460" Height="130"
        WindowStartupLocation="Manual">

    <Grid>
        <Border CornerRadius="10" Margin="4" Cursor="SizeAll">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F0071520" Offset="0"/>
                    <GradientStop Color="#EC050E18" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="5" Opacity="0.55"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top accent bar -->
                <Border x:Name="AccentBar" Grid.Row="0" CornerRadius="10,10,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#06B6D4" Offset="0"/>
                            <GradientStop Color="#3B82F6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Header: intent badge + confidence -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            Margin="12,6,12,3" VerticalAlignment="Center">
                    <Border x:Name="IntentBadge" Background="#06B6D4" CornerRadius="5" Padding="8,3">
                        <TextBlock x:Name="IntentText" Text="genel"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="White" FontFamily="Consolas"/>
                    </Border>
                    <TextBlock Text="AI Asistan" FontSize="10" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <TextBlock x:Name="ConfidenceText" FontSize="10" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Turkish summary -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="12,2,12,6">
                    <TextBlock x:Name="SummaryText"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#E2E8F0"
                               LineHeight="20">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </ScrollViewer>

                <!-- Warning (sadece uyarı varsa görünür) -->
                <TextBlock x:Name="WarningText"
                           Grid.Row="3"
                           Margin="12,0,12,6"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="#FCD34D"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Width="16" Height="16" Cursor="SizeNWSE" Margin="0,0,6,6" Opacity="0.35">
            <TextBlock Text="⠿" Foreground="White" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
