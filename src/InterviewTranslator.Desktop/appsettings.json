{
  "App": {
    "Audio": {
      "SampleRate": 16000,
      "Channels": 1
    },
    "AudioProcessing": {
      "LoopbackGain": 3.0,
      "ResamplerQuality": 1,
      "ChunkMs": 30
    },
    "Microphone": {
      "PreferredDeviceId": null
    },
    "Vad": {
      "SpeechThreshold": 0.003,
      "SilenceMs": 150,
      "MinSpeechMs": 80,
      "MaxSpeechMs": 800
    },
    "Stt": {
      "ModelPath": "workers/models/ggml-tiny.en.bin",
      "Language": "en",
      "ModelType": "tiny.en",
      "NoSpeechThreshold": 0.4,
      "Temperature": 0.0
    },
    "MicStt": {
      "ModelPath": "workers/models/ggml-tiny.bin",
      "Language": "auto",
      "ModelType": "tiny",
      "NoSpeechThreshold": 0.4,
      "Temperature": 0.0
    },
    "Translation": {
      "LibreTranslateUrl": "http://localhost:5050",
      "SourceLanguage": "en",
      "TargetLanguage": "tr",
      "TimeoutSeconds": 10
    },
    "ReverseTranslation": {
      "LibreTranslateUrl": "http://localhost:5050",
      "SourceLanguage": "tr",
      "TargetLanguage": "en",
      "TimeoutSeconds": 10
    },
    "Overlay": {
      "FontSize": 18,
      "Opacity": 0.85,
      "ShowEnglish": true,
      "MaxLines": 3
    },
    "Tts": {
      "Enabled": false,
      "Rate": 0,
      "Volume": 100
    },
    "Privacy": {
      "SaveAudio": false,
      "SaveTranscript": false,
      "DebugLog": false
    },
    "GitHubDocs": {
      "RawBaseUrl": "https://raw.githubusercontent.com/OCA1782/dotnet-interview-translator-docs/main",
      "TimeoutSeconds": 10
    },
    "OpenAI": {
      "ApiKey": "",
      "Mode": "AssistantOnly",
      "AssistantModel": "gpt-4o-mini",
      "MaxTokens": 300,
      "TimeoutSeconds": 8,
      "ShowCloudWarning": true
    }
  }
}
